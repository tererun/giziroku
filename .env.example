# HuggingFace access token (required for pyannote)
# https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API keys (comma-separated). Clients must send `X-API-Key` header.
API_KEYS=change-me-please,another-key-if-you-want

# Whisper model: tiny / base / small / medium / large-v2 / large-v3
WHISPER_MODEL=large-v3
# Compute type:
#   Pascal (GTX 10xx) -> int8_float32 (推奨) / int8 / float32
#   Volta以降 (RTX, A100等) -> int8_float16 / float16
WHISPER_COMPUTE_TYPE=int8_float32
# Device: cuda / cpu
DEVICE=cuda
# Default language: ja / en / ... / auto (auto-detect)
DEFAULT_LANGUAGE=ja

# Queue
MAX_QUEUE_SIZE=50
# Job result TTL in seconds
JOB_TTL=3600

# Streaming
STREAM_CHUNK_SECONDS=5.0
STREAM_SAMPLE_RATE=16000
